#!/bin/bash
# ==============================================================================
#  YouTube News (yt-new) - YouTube News Channel Player
#  Copyright (c) 2026 Yu-Sung Chang
#
#  Dependencies: 
#      - mpv       sudo apt install mpv
#      - yt-dlp    https://github.com/yt-dlp/yt-dlp/wiki/Installation (newest)
# ==============================================================================


MPV_OPTS="${MPV_OPTS:--ytdl-format="bestvideo[height<=480]+bestaudio/best[height<=480]" --volume=20 --framedrop=vo --slang=en --no-cache --demuxer-max-bytes=10M --demuxer-max-back-bytes=1M}"
EST_DATE=$(TZ='America/New_York' date +'%B %-d, %Y')

while true; do

INPUT=$(whiptail \
    --title "Live News Launcher" \
    --menu "Choose channel" \
    22 75 13 \
    "YTN Live"                               "KR" \
    "YonhapnewsTV Live"                      "KR" \
    "KBS 24"                                 "KR" \
    "MBC News 24/7"                          "KR" \
    "ABC News Live"                          "US" \
    "CBS News 24/7"                          "US" \
    "NBC News Now"                           "US" \
    "LiveNOW from FOX"                       "US" \
    "Bloomberg Business News Live"           "US" \
    "PBS NewsHour $EST_DATE"                 "US" \
    "Manual Search"                          "" \
    "Quit"                                   "" \
    3>&1 1>&2 2>&3)

# Cancel pressed
[ $? -ne 0 ] && exit 0

# Quit option
[ "$INPUT" = "Quit" ] && exit 0

# ----------------------------
# Manual keyword input
# ----------------------------
if [ "$INPUT" = "Manual Search" ]; then
    INPUT=$(whiptail \
        --inputbox "Enter YouTube search keyword:" \
        10 60 \
        3>&1 1>&2 2>&3)

    # cancelled input
    [ $? -ne 0 ] && continue
fi

clear
echo "Searching YouTube for: $INPUT"

VIDEO_ID=$(yt-dlp "ytsearch1:$INPUT live" --get-id 2>/dev/null)

if [ -z "$VIDEO_ID" ]; then
    whiptail --msgbox "No video found for:\n$INPUT" 10 60
    continue
fi

URL="https://www.youtube.com/watch?v=$VIDEO_ID"

echo "Playing: $URL"

pkill -x mpv 2>/dev/null
mpv $MPV_OPTS "$URL"
sleep 1

done

# Cleanup on exit
pkill -x mpv 2>/dev/null
clear
echo "Exited cleanly"
